<mxfile host="app.diagrams.net" agent="claude" version="29.5.2">
  <diagram id="deploy" name="DeployFlow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Deploy &amp; Packaging  ·  make deploy → do_copy → do_fileset → do_packup" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="34" as="geometry" />
        </mxCell>
        <mxCell id="entry" value="make deploy  /  make deploy_sdk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="(1) do_copy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=15;fontStyle=1;fontColor=#1B5E20;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="380" height="380" as="geometry" />
        </mxCell>
        <mxCell id="s1_a" value="overlay deploy/&lt;DEVICE_PLATFORM&gt;/&#10;fallback deploy/&lt;VKIT_PLATFORM&gt;/&#10;onto prebuilt/&lt;DEVICE_PLATFORM&gt;/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s1_b" value="setup/&lt;DEVICE_PLATFORM&gt;/&#10;→ prebuilt/&lt;DEVICE_PLATFORM&gt;/etc/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s1_c" value="QNX:    pull libsqlite3 / libicu*&#10;Android:  pull libc++_shared.so" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s1_d" value="Promote prebuilt-private/bin/&#10;iox-roudi  ·  iox-introspection-client&#10;fast-discovery-server  →  prebuilt/bin/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="340" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s1_e" value="QNX:  strip prebuilt/lib/*.sym" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="(2) do_fileset  ·  QNX only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=15;fontStyle=1;fontColor=#5D4037;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="450" y="170" width="380" height="380" as="geometry" />
        </mxCell>
        <mxCell id="s2_a" value="walk prebuilt/&lt;DEVICE_PLATFORM&gt;/&#10;filter via vkit.ignore" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="220" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s2_b" value="path rewrite:  lib/  →  lib64/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="280" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s2_c" value="exclude  *.a *.la *.sym *.o *.in&#10;include/ python/ cmake/ pkgconfig/&#10;src/ source/ test/ example/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="340" width="340" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s2_d" value="symlinks recorded as [type=link]&#10;(VERSION_REL=QHS_SDP220 adds permission metadata)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="410" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s2_e" value="output  prebuilt/&lt;DEVICE_PLATFORM&gt;/vkit.build" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="470" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="(3) do_packup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=15;fontStyle=1;fontColor=#BF360C;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="860" y="170" width="380" height="380" as="geometry" />
        </mxCell>
        <mxCell id="s3_a" value="rsync sync to&#10;packup/&lt;DEVICE_PLATFORM&gt;/&#10;{cmake, host, target}/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="880" y="220" width="340" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s3_b" value="generate vkit-runtime-setup.sh&#10;(auto-inject VLINK_ROOT_DIR etc.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="880" y="290" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3_c" value="generate vkit-sdk-setup.sh&#10;(adds host toolchain + cmake config)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="880" y="350" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3_d" value="VKIT_PACKUP_RUNTIME=1 →&#10;packup/vkit-&lt;DEVICE_PLATFORM&gt;-runtime.tgz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#BF360C;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="410" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3_e" value="VKIT_PACKUP_SDK=1 (or make deploy_sdk)&#10;→ packup/vkit-&lt;DEVICE_PLATFORM&gt;-sdk.tgz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#BF360C;fontSize=11;fontStyle=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="470" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ar1" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#2E7D32;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="entry" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ar2" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#F9A825;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ar3" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="Non-QNX platforms skip do_fileset and proceed directly to do_packup" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="1200" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
