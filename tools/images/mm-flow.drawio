        <mxCell id="e9" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="cmake_build" target="cmake_inst">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="endArrow=classic;html=1;rounded=0;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;strokeColor=#2E7D32;" edge="1" parent="1" source="cmake_d" target="cmake_build">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10l" value="yes → skip configure" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#2E7D32;" vertex="1" connectable="0" parent="e10">
          <mxGeometry relative="1" as="geometry" />
