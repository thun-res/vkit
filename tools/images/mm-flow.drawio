<mxfile host="app.diagrams.net" agent="claude" version="29.5.2">
  <diagram id="mmflow" name="MmFlow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="mm  ·  Single-Component Build Flow  ·  Auto-Detect Build System" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="34" as="geometry" />
        </mxCell>
        <mxCell id="enter" value="cd &lt;component-dir&gt;&#10;mm  /  mmm" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="d_kind" value="What is in the&#10;component root ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="520" y="170" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r_cmake" value="CMakeLists.txt&#10;or cmake/CMakeLists.txt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_buildsh" value="build.sh" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="290" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_make" value="Makefile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="290" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_skip" value="empty / missing&#10;(only in batch mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="290" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cmake_d" value="build/&lt;plat&gt;/&lt;proj&gt;/CMakeCache.txt exists ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cmake_cfg" value="cmake -S &lt;src&gt; -B &lt;build&gt;&#10;-DCMAKE_TOOLCHAIN_FILE=…&#10;append cfg / CLI -D… flags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cmake_build" value="cmake --build &lt;build&gt; -j$VKIT_BUILD_CPU_CORE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cmake_inst" value="cmake --install &lt;build&gt;&#10;(VKIT_STRIP=1 adds --strip)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="bsh_run" value="copy dir to build/&#10;then run build.sh" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="500" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="mk_run" value="make -C &lt;src&gt; -j$VKIT_BUILD_CPU_CORE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="500" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="skip_run" value="print Skip [&lt;proj&gt;]&#10;return success" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="940" y="500" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="caveat" value="Caveat: cache stickiness&#10;Once CMakeCache.txt exists, subsequent mm calls skip cmake -S/-B&#10;and any newly appended -D… is ignored.&#10;Run mm clean / mm dclean before switching configure-time flags." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#D32F2F;fontSize=11;fontStyle=2;fontColor=#B71C1C;" vertex="1" parent="1">
          <mxGeometry x="380" y="600" width="520" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="enter" target="d_kind">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="d_kind" target="r_cmake">
