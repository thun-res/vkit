        <mxCell id="priv_role" value="No - not synced into packup/target&#10;No - not included in SDK by default&#10;Special - do_copy promotes iox-roudi, iox-introspection-client,&#10;        fast-discovery-server to prebuilt/bin/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D32F2F;fontSize=11;fontStyle=2;" vertex="1" parent="1">
