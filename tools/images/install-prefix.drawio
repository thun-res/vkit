          <mxGeometry x="490" y="190" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pub" value="prebuilt/&lt;DEVICE_PLATFORM&gt;/&#10;&#10;Shipping artifacts: services, CLIs, shared libs, configs&#10;CMAKE_INSTALL_PREFIX = $VKIT_PREBUILT_DIR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontColor=#1B5E20;" vertex="1" parent="1">
