        <mxCell id="title" value="Public / Private Install Prefix  ·  Link-only deps stay outside packages by default" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="34" as="geometry" />
        </mxCell>
        <mxCell id="comp" value="Component (thirdparty / vendor / middleware / app)&#10;cfg line:  &lt;path&gt; ; -DENABLE_INSTALL_PRIVATE=ON | OFF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="90" width="400" height="70" as="geometry" />
