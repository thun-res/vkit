        <mxCell id="priv" value="prebuilt-private/&lt;DEVICE_PLATFORM&gt;/&#10;&#10;Link-only, not packaged by default: boost, asio, json, yaml-cpp,&#10;foonathan_memory, Fast-CDR …&#10;cmake/toolchain.cmake auto-adds -I/-L/find/pkgconfig" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#D32F2F;fontSize=12;fontColor=#B71C1C;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="320" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="pub_role" value="Yes - included in runtime tarball&#10;Yes - included in SDK tarball&#10;Yes - resolved at runtime via LD_LIBRARY_PATH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;fontStyle=2;" vertex="1" parent="1">
