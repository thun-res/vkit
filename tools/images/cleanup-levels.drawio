<mxfile host="app.diagrams.net" agent="claude" version="29.5.2">
  <diagram id="cleanup" name="CleanupLevels">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Cleanup Levels  ·  Four-Tier Cleanup Gradient" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="34" as="geometry" />
        </mxCell>
        <mxCell id="lvl1" value="(1)  make clean&#10;Light  ·  current platform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=14;fontStyle=1;fontColor=#1B5E20;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="290" height="380" as="geometry" />
        </mxCell>
        <mxCell id="l1_b" value="Yes - delete each component's&#10;       build/&lt;platform&gt;/&lt;proj&gt;/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="l1_p" value="No  - preserves prebuilt/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l1_pp" value="No  - preserves prebuilt-private/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l1_k" value="No  - preserves packup/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l1_use" value="Use when:  daily incremental&#10;             build fails — start over" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lvl2" value="(2)  make rclean&#10;Reset  ·  current platform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=14;fontStyle=1;fontColor=#5D4037;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="350" y="100" width="290" height="380" as="geometry" />
        </mxCell>
        <mxCell id="l2_b" value="Yes - wipe build/&lt;platform&gt;/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="370" y="160" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l2_p" value="Yes - prebuilt/&lt;platform&gt;/&#10;       git repo: clean + checkout&#10;       non-git:  wipe contents" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="370" y="210" width="250" height="60" as="geometry" />
