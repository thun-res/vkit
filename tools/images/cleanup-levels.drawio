          <mxGeometry x="370" y="280" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l2_k" value="Yes - wipe packup/&lt;platform&gt;/&#10;Yes - delete platform tgz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9A825;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="370" y="330" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="l2_use" value="Use when:  reset dirty state but&#10;             keep git-tracked prebuilt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="370" y="400" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lvl3" value="(3)  make dclean&#10;Deep  ·  current platform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=14;fontStyle=1;fontColor=#BF360C;verticalAlign=top;" vertex="1" parent="1">
