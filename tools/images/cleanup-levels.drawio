        </mxCell>
        <mxCell id="l3_use" value="Use when:  prebuilt suspected bad —&#10;             rebuild fully from source" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;fontStyle=2;align=left;" vertex="1" parent="1">
