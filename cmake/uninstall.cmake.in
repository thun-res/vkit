function(uninstall_from_manifest manifest_file)
  file(READ "${manifest_file}" files)
  string(REGEX REPLACE "\n" ";" files "${files}")
  foreach(file ${files})
    if(NOT file)
      continue()
    endif()
    message(STATUS "Uninstalling ${file}")
    if(IS_SYMLINK "${file}" OR EXISTS "${file}")
      execute_process(COMMAND "@CMAKE_COMMAND@" -E remove "${file}" RESULT_VARIABLE rm_retval)
      if(NOT "${rm_retval}" EQUAL 0)
        message(FATAL_ERROR "Problem when removing ${file}")
      endif()
    else()
      message(STATUS "File ${file} does not exist.")
    endif()
  endforeach()
endfunction()

if(EXISTS "@CMAKE_BINARY_DIR@/install_manifest.txt")
  uninstall_from_manifest("@CMAKE_BINARY_DIR@/install_manifest.txt")
else()
  message(FATAL_ERROR "Cannot find install manifest: @CMAKE_BINARY_DIR@/install_manifest.txt")
endif()

if(EXISTS "@CMAKE_BINARY_DIR@/symlinks_manifest.txt")
  uninstall_from_manifest("@CMAKE_BINARY_DIR@/symlinks_manifest.txt")
endif()
